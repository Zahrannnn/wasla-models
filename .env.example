# ── LLM provider ───────────────────────────────────────────────
# Local Ollama (default in app/core/config.py):
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
MAIN_CHAT_MODEL=qwen2.5:3b
FALLBACK_CHAT_MODEL=qwen2.5:3b
# Pull once:  ollama pull qwen2.5:3b

# Option A — OpenRouter (unset LLM_PROVIDER or set LLM_PROVIDER=openrouter):
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-v1-xxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# MAIN_CHAT_MODEL=arcee-ai/trinity-large-preview:free
# FALLBACK_CHAT_MODEL=google/gemma-3n-e4b-it:free

# Option B — HuggingFace router:
# LLM_PROVIDER=openrouter
# LLM_API_KEY=hf_xxxx
# LLM_BASE_URL=https://router.huggingface.co/v1

# ── Agent loop settings ──────────────────────────────────────
MAX_TOOL_ITERATIONS=3
MAX_CHAT_TOKENS=1024
MAX_VOICE_TOKENS=250

# ── Context window limit ─────────────────────────────────────
MAX_CONTEXT_TOKENS=8192

# ── Customer Portal API ──────────────────────────────────────
CRM_API_BASE_URL=http://waslacrm.runasp.net/api/customer-portal
CRM_API_TIMEOUT_SECONDS=10

# ── Company Portal API (staff-facing) ────────────────────────
COMPANY_API_BASE_URL=http://waslacrm.runasp.net/api
COMPANY_API_TIMEOUT_SECONDS=10

# ── TTS (Kokoro-82M local) ───────────────────────────────────
TTS_VOICE=af_heart
TTS_LANG_CODE=a

# ── STT (Hugging Face Inference API) ─────────────────────────
STT_MODEL=openai/whisper-large-v3-turbo
