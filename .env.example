# ── Hugging Face API Token (free tier) ────────────────────────
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=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

# ── Model Configuration ──────────────────────────────────────
MAIN_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct
VOICE_STREAM_MODEL=meta-llama/Llama-3.1-8B-Instruct
FALLBACK_CHAT_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Agent loop settings ──────────────────────────────────────
MAX_TOOL_ITERATIONS=3
MAX_CHAT_TOKENS=1024
MAX_VOICE_TOKENS=250

# ── Context window limit (HF free tier) ──────────────────────
MAX_CONTEXT_TOKENS=8192

# ── Redis (rate limiting) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── TTS (Kokoro-82M local) ────────────────────────────────────
TTS_VOICE=af_heart
TTS_LANG_CODE=a

# ── STT (Hugging Face Inference API) ─────────────────────────
STT_MODEL=openai/whisper-large-v3-turbo
