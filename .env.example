# ── LLM Provider (any OpenAI-compatible endpoint) ────────────
# Option A — OpenRouter (free tier, no credit card needed):
#   1. Sign up at https://openrouter.ai
#   2. Get API key from https://openrouter.ai/settings/keys
# LLM_API_KEY=sk-or-v1-xxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Option B — HuggingFace:
# LLM_API_KEY=hf_xxxx
# LLM_BASE_URL=https://router.huggingface.co/v1

# ── Model Configuration ──────────────────────────────────────
# Free models on OpenRouter (append :free for free tier):
MAIN_CHAT_MODEL=qwen/qwen3-14b:free
VOICE_STREAM_MODEL=qwen/qwen3-8b:free
FALLBACK_CHAT_MODEL=qwen/qwen3-8b:free

# ── Agent loop settings ──────────────────────────────────────
MAX_TOOL_ITERATIONS=3
MAX_CHAT_TOKENS=1024
MAX_VOICE_TOKENS=250

# ── Context window limit ─────────────────────────────────────
MAX_CONTEXT_TOKENS=8192

# ── Customer Portal API ──────────────────────────────────────
CRM_API_BASE_URL=http://waslacrm.runasp.net/api/customer-portal
CRM_API_TIMEOUT_SECONDS=10

# ── Company Portal API (staff-facing) ────────────────────────
COMPANY_API_BASE_URL=http://waslacrm.runasp.net/api
COMPANY_API_TIMEOUT_SECONDS=10

# ── TTS (Kokoro-82M local) ───────────────────────────────────
TTS_VOICE=af_heart
TTS_LANG_CODE=a

# ── STT (Hugging Face Inference API) ─────────────────────────
STT_MODEL=openai/whisper-large-v3-turbo
